# Gemini Configuration
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-native-audio-dialog
GEMINI_SYSTEM_MESSAGE=You are a friendly and helpful AI voice assistant on a phone call. Be concise and clear.
GEMINI_AUDIO_CHUNK_COUNT=20

# Server Configuration
SERVER_DOMAIN=your_ngrok_domain.ngrok.io

# Teler Configuration
TELER_API_KEY=your_teler_api_key_here

